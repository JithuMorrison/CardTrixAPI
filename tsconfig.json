{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": false,
    "outDir": "./dist",
    "rootDir": "..",
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "../shared/**/*"]
}
